import { call } from "../src/lib"

// Exercises the rails-style form encoder end-to-end through `api.request` (which
// form-encodes v1 bodies) and asserts the exact wire output. `http_mock_calls`
// records the encoded request body, so these are true encoder assertions rather
// than a re-implementation.
@complexity(allow)
pipeline default() {
  egress_policy({allow: ["stripe-api.test"], default: "deny"})
  http_mock_clear()
  const base = "https://stripe-api.test"
  const key = "sk_test_123"
  // Nested dicts, lists of dicts, booleans, url-encoded scalars, nil omission,
  // and deterministic alphabetical key ordering.
  http_mock("POST", base + "/v1/echo", {status: 200, body: "{\"ok\":true}"})
  call(
    "api.request",
    {
      api_base_url: base,
      api_key: key,
      body: {
        active: true,
        disabled: false,
        line_items: [{price: "p1", quantity: 2}, {price: "p2"}],
        metadata: {note: "a@b c", plan: "pro"},
        skip: nil,
        url: "https://x.test/c",
      },
      method: "POST",
      path: "/v1/echo",
    },
  )
  const encoded = http_mock_calls()[0].body
  assert_eq(
    encoded,
    "active=true&disabled=false&line_items[0][price]=p1&line_items[0][quantity]=2"
      + "&line_items[1][price]=p2&metadata[note]=a%40b%20c&metadata[plan]=pro"
      + "&url=https%3A%2F%2Fx.test%2Fc",
    "nested form encoding is deterministic and url-encoded",
  )
  // Empty body encodes to the empty string.
  http_mock_clear()
  http_mock("POST", base + "/v1/empty", {status: 200, body: "{}"})
  call(
    "api.request",
    {api_base_url: base, api_key: key, body: {}, method: "POST", path: "/v1/empty"},
  )
  assert_eq(http_mock_calls()[0].body, "", "empty dict encodes to empty string")
  http_mock_clear()
}
